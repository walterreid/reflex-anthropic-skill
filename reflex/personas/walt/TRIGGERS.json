{
  "triggers": {
    "needs_research": {
      "signals": [
        "I don't know enough about",
        "what's the market like",
        "who are the competitors",
        "is there data on",
        "what's happening with",
        "I've heard about but don't know",
        "can you look into",
        "what do we know about"
      ],
      "suggest_modules": ["research", "websearch", "trends", "fetch"],
      "behavior": "invoke_with_signal",
      "note": "MUST use websearch/research/fetch via dispatch.py. Never use native web search. Signal briefly, then dispatch."
    },
    "needs_comparison": {
      "signals": [
        "compare",
        "versus",
        "which is better",
        "what's the difference between",
        "how does X stack up against",
        "pros and cons"
      ],
      "suggest_modules": ["compare", "evaluate", "landscape"],
      "behavior": "invoke_with_signal",
      "note": "MUST dispatch compare or evaluate module. Chain with websearch first if targets are external."
    },
    "needs_stress_test": {
      "signals": [
        "what could go wrong",
        "devil's advocate",
        "poke holes",
        "what am I missing",
        "is this actually good",
        "challenge this",
        "red team",
        "worst case"
      ],
      "suggest_modules": ["challenge", "risks", "perspective"],
      "behavior": "invoke_with_signal",
      "note": "MUST dispatch challenge/risks/perspective module. Don't soften — that defeats the purpose."
    },
    "needs_structure": {
      "signals": [
        "help me think through",
        "how should I approach",
        "what's the framework for",
        "organize my thinking",
        "break this down",
        "I'm overwhelmed"
      ],
      "suggest_modules": ["decompose", "ideate", "swot", "scenario"],
      "behavior": "invoke_with_signal",
      "note": "MUST dispatch a structuring module. Pick the framework that fits."
    },
    "wants_deliverable": {
      "signals": [
        "write that up",
        "send this as an email",
        "make a report",
        "put that in a doc",
        "draft a",
        "can you write",
        "I need to send",
        "package this",
        "turn this into"
      ],
      "suggest_modules": ["report", "email", "linkedin", "pitch", "whitepaper"],
      "behavior": "confirm_format_then_invoke",
      "note": "MUST dispatch a formatter module. Never write deliverables with native file tools. Confirm format/audience, then chain research into the formatter via dispatch."
    },
    "wants_next_steps": {
      "signals": [
        "what should I do next",
        "next steps",
        "what now",
        "where do I go from here",
        "action items",
        "make this actionable"
      ],
      "suggest_modules": ["actions", "experiment"],
      "behavior": "invoke_with_signal",
      "note": "MUST dispatch actions or experiment module."
    },
    "situation_shift": {
      "signals": [
        "actually let's talk about",
        "switching gears",
        "different topic",
        "change of subject",
        "one more thing",
        "unrelated but"
      ],
      "behavior": "acknowledge_and_pivot",
      "note": "Don't fight the shift. Acknowledge, snapshot if useful, then follow."
    },
    "wants_to_preserve": {
      "signals": [
        "save this",
        "remember this",
        "I want to come back to",
        "don't lose this",
        "capture what we discussed"
      ],
      "suggest_modules": ["context", "snapshot", "recap"],
      "behavior": "invoke_with_signal",
      "note": "MUST dispatch context/snapshot/recap module to persist state."
    },
    "wants_audience_adaptation": {
      "signals": [
        "explain this to my",
        "how would I tell",
        "make this simpler",
        "for a non-technical",
        "for my boss",
        "for the board",
        "for investors"
      ],
      "suggest_modules": ["simplify", "reframe", "persona"],
      "behavior": "invoke_with_signal",
      "note": "MUST dispatch simplify/reframe module via dispatch.py."
    }
  }
}
